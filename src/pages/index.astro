---
import "../styles/global.css";

const socialLinks = [
  { platform: 'Facebook', url: 'https://www.facebook.com/ioannis.lougiakis' },
  { platform: 'Instagram', url: 'https://www.instagram.com/ioannislo' },
];

const skills = [
  'HTML & CSS',
  'JavaScript',
  'Responsive Design',
  'Web Performance',
  'UI/UX Fundamentals',
  'Accessibility',
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content="Ioannis Lougiakis — frontend developer focused on clean, performant web experiences." />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>Ioannis Lo — Frontend Developer</title>
  <script is:inline>
    if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="bg-white text-neutral-900 dark:bg-[#0a0a0a] dark:text-[#ededed] font-sans antialiased selection:bg-neutral-900 selection:text-white dark:selection:bg-[#ededed] dark:selection:text-[#0a0a0a] transition-colors duration-300">
<div class="mx-auto max-w-xl px-6 py-10 md:py-16 min-h-screen flex flex-col">

  <header class="mb-20 md:mb-28 flex items-center justify-between sticky top-0 z-50 py-5 bg-white/90 dark:bg-[#0a0a0a]/90 backdrop-blur-sm -mx-6 px-6 border-b border-neutral-100 dark:border-white/[0.06] transition-colors duration-300">
    <a href="#home" class="font-semibold text-sm text-neutral-900 dark:text-white">
      ioannislo
    </a>
    <div class="flex items-center gap-7">
      <nav>
        <ul class="flex gap-5 text-sm text-neutral-500 dark:text-neutral-400">
          <li><a href="#about" class="hover:text-neutral-900 dark:hover:text-white transition-colors">About</a></li>
          <li><a href="#skills" class="hover:text-neutral-900 dark:hover:text-white transition-colors">Skills</a></li>
          <li><a href="#contact" class="hover:text-neutral-900 dark:hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition-colors cursor-pointer"
      >
        <svg id="theme-toggle-dark-icon" class="hidden w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
        </svg>
        <svg id="theme-toggle-light-icon" class="hidden w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z"></path>
        </svg>
      </button>
    </div>
  </header>

  <main class="flex flex-col gap-24 md:gap-32">

    <section id="home">
      <p class="text-sm text-neutral-400 dark:text-neutral-500 mb-5">Ioannis Lougiakis</p>
      <h1 class="text-4xl md:text-[2.75rem] font-bold text-neutral-900 dark:text-white mb-5 tracking-tight leading-[1.15]">
        Frontend developer,<br />building for the web.
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400 text-base leading-relaxed mb-10">
        Focused on the fundamentals — clean HTML, thoughtful CSS,
        and JavaScript that does exactly what it needs to.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/IOANNIS_LOUGIAKIS_CV.pdf"
          download="IOANNIS_LOUGIAKIS_CV.pdf"
          class="px-4 py-2 rounded-md bg-neutral-900 dark:bg-white text-white dark:text-black text-sm font-medium hover:bg-neutral-700 dark:hover:bg-neutral-100 transition-colors"
        >
          Download CV
        </a>
        <a
          href="#contact"
          class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors"
        >
          Get in touch →
        </a>
      </div>
    </section>

    <section id="about">
      <h2 class="text-[11px] font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-[0.12em] mb-6">About</h2>
      <div class="space-y-4 text-neutral-600 dark:text-neutral-400 leading-[1.8] text-[0.9375rem]">
        <p>
          I'm at the start of my journey in web development, focused on building a strong foundation.
          I enjoy turning designs into working code and picking up new things along the way.
        </p>
        <p>
          My goal is to write accessible, performant websites — and to keep getting better as the craft evolves.
        </p>
      </div>
    </section>

    <section id="skills">
      <h2 class="text-[11px] font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-[0.12em] mb-6">Skills</h2>
      <ul class="divide-y divide-neutral-100 dark:divide-neutral-800/70">
        {skills.map(item => (
          <li class="py-3 text-[0.9375rem] text-neutral-700 dark:text-neutral-300 first:pt-0 last:pb-0">
            {item}
          </li>
        ))}
      </ul>
    </section>

    <section id="contact">
      <h2 class="text-[11px] font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-[0.12em] mb-6">Contact</h2>
      <p class="text-neutral-600 dark:text-neutral-400 text-[0.9375rem] leading-[1.8] mb-7">
        Open to opportunities, collaborations, or just a conversation.
      </p>
      <div class="space-y-5">
        <a
          href="mailto:ioannis.lougiakis@gmail.com"
          class="block text-neutral-900 dark:text-white text-[0.9375rem] font-medium hover:text-neutral-500 dark:hover:text-neutral-400 transition-colors"
        >
          ioannis.lougiakis@gmail.com →
        </a>
        <div class="flex gap-4 text-sm text-neutral-500 dark:text-neutral-400">
          {socialLinks.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-neutral-900 dark:hover:text-white transition-colors"
            >
              {link.platform}
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <footer class="mt-auto pt-20 pb-2 text-xs text-neutral-400 dark:text-neutral-600">
    &copy; {new Date().getFullYear()} Ioannis Lougiakis
  </footer>

</div>
</body>
</html>

<script is:inline>
  const btn = document.getElementById('theme-toggle');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');
  const lightIcon = document.getElementById('theme-toggle-light-icon');

  const isDark = () => document.documentElement.classList.contains('dark');

  (isDark() ? lightIcon : darkIcon).classList.remove('hidden');

  btn.addEventListener('click', () => {
    darkIcon.classList.toggle('hidden');
    lightIcon.classList.toggle('hidden');
    const dark = isDark();
    document.documentElement.classList.toggle('dark', !dark);
    localStorage.setItem('color-theme', dark ? 'light' : 'dark');
  });
</script>

